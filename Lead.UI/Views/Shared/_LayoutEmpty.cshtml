@using Common.Utils.Constant
@using Core.ViewModels.Dto.Auth
@using Core.ViewModels.Dto.Auth.Auth
@{
    ViewData["Version"] = "1.0";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <meta name="description" content="">
    <meta name="author" content="">

    <title>Lead - Dashboard</title>


    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link href="~/css/jquery.toast.min.css" rel="stylesheet" />
    <!-- Custom fonts for this template-->
    <link href="~/sb-admin/vendor/fontawesome-free/css/all.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css?family=Nunito:200,200i,300,300i,400,400i,600,600i,700,700i,800,800i,900,900i"
          rel="stylesheet">

    <!-- Custom styles for this template-->
    <link href="~/sb-admin/css/sb-admin-2.css" rel="stylesheet" />
    @* <link href="~/css/tables.css" rel="stylesheet" /> *@
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <main>
        @RenderBody()
    </main>
    <footer style="background-color: #f8f9fa; text-align: center; padding: 10px 0; position: fixed; bottom: 0; width: 100%; border-top: 1px solid #ddd;">
        <p style="margin: 0; font-size: 0.9rem">&copy; @DateTime.Now.Year <a href="https://khanit.com.bd" target="_blank"><strong>Khan Lead</strong></a>. All rights reserved.</p>
    </footer>

    <!-- Bootstrap core JavaScript-->
    @* <script src="~/lib/jquery/dist/jquery.min.js"></script> *@
    <script src="~/sb-admin/vendor/jquery/jquery.min.js"></script>
    @* <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script> *@
    <script src="~/sb-admin/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <!-- Core plugin JavaScript-->
    <script src="~/sb-admin/vendor/jquery-easing/jquery.easing.min.js"></script>

    <!-- Custom scripts for all pages-->
    <script src="~/sb-admin/js/sb-admin-2.min.js"></script>

    <script src="~/js/jquery.toast.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
