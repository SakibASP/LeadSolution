@model Core.ViewModels.Dto.Auth.Auth.ProfileViewModel

@{
    ViewData["Title"] = "Profile Management";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-7">
            <div class="card shadow-lg border-0 rounded-lg">

                <!-- Header with Username -->
                <div class="card-header text-white text-center py-4"
                     style="background: linear-gradient(90deg, #0d6efd, #6610f2);">
                    <h3 class="mb-0 font-weight-bold">👤 @Model.UserName</h3>
                    <small class="d-block text-light">Manage your profile & password</small>
                </div>

                <div class="card-body p-4">

                    <!-- Tab Buttons -->
                    <ul class="nav nav-pills justify-content-center mb-4" id="profileTab" role="tablist">
                        <li class="nav-item">
                            <a class="nav-link active" id="profile-tab" data-toggle="pill" href="#profile-info"
                               role="tab" aria-controls="profile-info" aria-selected="true">
                                <i class="fa fa-user mr-1"></i> Profile Information
                            </a>
                        </li>
                        <li class="nav-item ml-2">
                            <a class="nav-link" id="password-tab" data-toggle="pill" href="#change-password"
                               role="tab" aria-controls="change-password" aria-selected="false">
                                <i class="fa fa-lock mr-1"></i> Change Password
                            </a>
                        </li>
                    </ul>

                    <!-- Tab Content -->
                    <div class="tab-content" id="profileTabContent">

                        @if (TempData["UserSuccess"] != null)
                        {
                            <div class="alert alert-success alert-dismissible fade show" role="alert">
                                <i class="fa fa-check-circle mr-2"></i>
                                @TempData["UserSuccess"]
                                <button type="button" class="close" data-dismiss="alert">
                                    <span>&times;</span>
                                </button>
                            </div>
                        }
                        <!-- Profile Info -->
                        <div class="tab-pane fade show active" id="profile-info" role="tabpanel" aria-labelledby="profile-tab">
                            <form asp-action="UpdateProfile" method="post">
                                <div class="form-group mb-4">
                                    <label asp-for="Email" class="font-weight-bold"></label>
                                    <input asp-for="Email" class="form-control" type="email" placeholder="Enter email" />
                                    <span asp-validation-for="Email" class="text-danger"></span>
                                </div>

                                <div class="form-group mb-4">
                                    <label asp-for="PhoneNumber" class="font-weight-bold"></label>
                                    <input asp-for="PhoneNumber" class="form-control" placeholder="Enter phone number" />
                                    <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                                </div>

                                <div class="form-group mb-4">
                                    <label asp-for="NID" class="font-weight-bold"></label>
                                    <input asp-for="NID" class="form-control" placeholder="Enter National ID" />
                                    <span asp-validation-for="NID" class="text-danger"></span>
                                </div>

                                <div class="text-center mt-4">
                                    <button type="submit" class="btn btn-success px-5 shadow">
                                        <i class="fa fa-save mr-2"></i> Save Changes
                                    </button>
                                </div>
                            </form>
                        </div>

                        <!-- Change Password -->
                        <div class="tab-pane fade" id="change-password" role="tabpanel" aria-labelledby="password-tab">
                            <form asp-action="ChangePassword" method="post">
                                <input type="hidden" asp-for="Email" />
                                <div class="form-group mb-3">
                                    <label asp-for="CurrentPassword" class="font-weight-bold"></label>
                                    <input asp-for="CurrentPassword" type="password" class="form-control"
                                           placeholder="Enter current password" autocomplete="off" required />
                                </div>

                                <div class="form-group mb-3">
                                    <label asp-for="NewPassword" class="font-weight-bold"></label>
                                    <input asp-for="NewPassword" type="password" class="form-control"
                                           placeholder="Enter new password" autocomplete="off" required />
                                </div>

                                <div class="form-group mb-3">
                                    <label asp-for="ConfirmPassword" class="font-weight-bold"></label>
                                    <input asp-for="ConfirmPassword" type="password" class="form-control"
                                           placeholder="Confirm new password" autocomplete="off" required />
                                    <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                                </div>

                                <div class="text-center mt-4">
                                    <button type="submit" class="btn btn-primary px-5 shadow">
                                        <i class="fa fa-lock mr-2"></i> Update Password
                                    </button>
                                </div>
                            </form>
                        </div>

                    </div> <!-- End Tab Content -->

                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
