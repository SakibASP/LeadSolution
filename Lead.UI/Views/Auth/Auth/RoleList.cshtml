@model IList<Core.ViewModels.Dto.Auth.RoleDto>

@{
    ViewData["Title"] = "Home Page";
}

<form method="post" asp-action="AddRole" asp-controller="Auth" class="col-sm-6">
    <div class="input-group">
        <input name="roleName" class="form-control" style="margin-right: 5px">
        <span class="input-group-btn">
            <button class="btn btn-info">Add New Role</button>
        </span>
    </div>
</form>
<br />
<div class="table-responsive">
    <table id="dataTableExample1" class="table table-bordered table-striped table-hover">
        <thead class="back_table_color">
            <tr class="info">
                <th>Role</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var role in Model)
            {
                <tr>
                    @*<td>@role.Id</td>*@
                    <td>
                        @role.Name
                    </td>
                    <td>
                        @Html.ActionLink("Edit", "EditRole", "Auth", new { roleName = role.Name, id = role.Id }, new { @class = "btn btn-info btn-sm" })
                        @Html.ActionLink("Delete", "DeleteRole", "Auth", new { roleName = role.Name }, new { @class = "btn btn-danger btn-sm" })
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>