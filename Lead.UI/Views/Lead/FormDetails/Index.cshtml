@model IEnumerable<Core.Models.Lead.FormDetails>

@{
    ViewData["Title"] = "Form Details";
}



<div class="card shadow rounded">
    <div class="card-header">
        <div class="d-flex justify-content-between align-items-center">
            <h2 class="text-primary fw-bold">Form Details</h2>
            <a asp-action="Create" class="btn btn-success shadow-sm">
                <i class="fas fa-plus-circle me-1"></i> Create New
            </a>
        </div>
    </div>
    <div class="card-body">
        <table class="table table-bordered table-hover" id="dataTable">
            <thead class="table-dark">
                <tr>
                    <th>@Html.DisplayNameFor(model => model.First().Name)</th>
                    <th>@Html.DisplayNameFor(model => model.First().DataTypeId)</th>
                    <th>@Html.DisplayNameFor(model => model.First().IsSelectInput)</th>
                    <th>@Html.DisplayNameFor(model => model.First().IsActive)</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Name</td>
                        <td>@item.DataTypes?.Name</td>
                        <td>
                            <span class="badge bg-@(item.IsSelectInput ? "success" : "danger")">
                                @(item.IsSelectInput ? "Yes" : "No")
                            </span>
                        </td>
                        <td>
                            <span class="badge bg-@(item.IsActive ? "success" : "danger")">
                                @(item.IsActive ? "Yes" : "No")
                            </span>
                        </td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary me-1">
                                <i class="fas fa-edit"></i> Edit
                            </a>
                            <button type="button"
                                    class="btn btn-sm btn-outline-danger"
                                    onclick="confirmDelete('@Url.Action("Remove", "FormDetails", new { item.Id })')">
                                <i class="fas fa-trash-alt"></i> Delete
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
