@model IEnumerable<Core.Models.Lead.FormDetails>

@{
    ViewData["Title"] = "Form Details";
}

<div class="mt-5">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="text-primary">Form Details</h2>
        <a asp-action="Create" class="btn btn-success">
            <i class="fas fa-plus-circle"></i> Create New
        </a>
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-striped table-hover mb-0">
                    <thead class="thead-dark">
                        <tr>
                            <th>@Html.DisplayNameFor(model => model.First().Name)</th>
                            <th>@Html.DisplayNameFor(model => model.First().IsNullSupported)</th>
                            <th>@Html.DisplayNameFor(model => model.First().IsSelectInput)</th>
                            <th>@Html.DisplayNameFor(model => model.First().IsActive)</th>
                            <th>@Html.DisplayNameFor(model => model.First().TypeId)</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.Name</td>
                                <td>@item.IsNullSupported</td>
                                <td>@item.IsSelectInput</td>
                                <td>@item.IsActive</td>
                                <td>@item.DataTypes?.Name</td>
                                <td class="text-center">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-primary btn-sm me-1">
                                        <i class="fas fa-edit"></i> Edit
                                    </a>
                                    <button type="button"
                                            class="btn btn-outline-danger btn-sm"
                                            onclick="confirmDelete('@Url.Action("Remove", "FormDetails", new { roleId = item.Id })')">
                                        <i class="fas fa-trash"></i> Delete
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>