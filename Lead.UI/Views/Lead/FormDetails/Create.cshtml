@model Core.Models.Lead.FormDetails

@{
    ViewData["Title"] = "Create Form Field";
}

<div class="container py-1">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow rounded-3">
                <div class="card-header bg-primary text-white text-center">
                    <h4 class="mb-0">Create Form Field</h4>
                </div>
                <div class="card-body">
                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="form-group mb-3">
                            <label asp-for="Name" class="form-label fw-bold"></label>
                            <input asp-for="Name" class="form-control" placeholder="Enter field name" />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="TypeId" class="form-label fw-bold"></label>
                            <select asp-for="TypeId" class="form-select" asp-items="ViewBag.TypeId">
                                <option disabled selected>-- Select Type --</option>
                            </select>
                        </div>


                        <div class="form-check form-switch mb-2">
                            <input class="form-check-input" asp-for="IsSelectInput" type="checkbox" />
                            <label class="form-check-label fw-semibold" asp-for="IsSelectInput"></label>
                        </div>

                        <div class="d-grid">
                            <button type="submit" class="btn btn-success btn-lg">
                                <i class="bi bi-plus-circle"></i> Create
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            <div class="text-center mt-3">
                <a asp-action="Index" class="text-decoration-none">
                    ← Back to List
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
