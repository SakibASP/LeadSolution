@using System.Text.Json
@{
    var rows = ViewBag.DynamicRows as List<Dictionary<string, object>>;
    var hiddenCols = new[] { "BusinessId", "SubmissionId" };
    var businessList = ViewBag.BusinessId as SelectList;
    var selectedBusiness = businessList?.FirstOrDefault(b => b.Value == businessList.SelectedValue.ToString())
                           ?? businessList?.FirstOrDefault();

    var today = DateTime.Today;
    var oneWeekAgo = today.AddDays(-7);
}


<div class="mt-2">
    <div class="card shadow-lg border-0 rounded-4">
        <!-- Filter Form -->
        <form asp-action="Index" method="get" id="submitForm" class="p-3 border-bottom">
            <div class="row g-2 align-items-center">
                <!-- Business Dropdown -->
                <div class="col-md-4">
                    <input type="hidden" name="businessId" id="businessId" value="@selectedBusiness?.Value" />

                    <div class="dropdown w-100">
                        <button class="btn btn-outline-primary w-100 text-left d-flex justify-content-between align-items-center rounded-pill px-3 py-2 shadow-sm"
                                type="button"
                                id="customDropdown" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                            <span>@(selectedBusiness?.Text ?? "🔍 Select a Business")</span>
                            <i class="fas fa-chevron-down"></i>
                        </button>

                        <div class="dropdown-menu w-100 border-0 shadow-lg rounded-3 mt-2 p-2"
                             aria-labelledby="customDropdown"
                             style="max-height: 350px; overflow-y: auto;">

                            <!-- Search box -->
                            <div class="mb-2">
                                <input type="text" class="form-control form-control-sm rounded-pill px-3"
                                       id="drpSearch" placeholder="Type to search..." />
                            </div>

                            <!-- Dropdown items -->
                            @if (businessList is not null)
                            {
                                foreach (var item in businessList)
                                {
                                    <a class="dropdown-item custom-dropdown-item rounded px-3 py-2 mb-1 @(item.Value == selectedBusiness?.Value ? "active bg-primary text-white" : "")"
                                       data-value="@item.Value"
                                       href="javascript:void(0)">
                                        <i class="fas fa-building mr-2"></i> @item.Text
                                    </a>
                                }
                            }
                        </div>
                    </div>
                </div>

                <!-- From Date -->
                <div class="col-md-2">
                    <input type="date" name="fromDate" class="form-control rounded-pill shadow-sm"
                           value="@oneWeekAgo.ToString("yyyy-MM-dd")" />
                </div>

                <!-- To Date -->
                <div class="col-md-2">
                    <input type="date" name="toDate" class="form-control rounded-pill shadow-sm"
                           value="@today.ToString("yyyy-MM-dd")" />
                </div>

                <!-- Submit Button -->
                <div class="col-md-2">
                    <button type="submit" class="btn btn-success w-100 rounded-pill shadow-sm">
                        <i class="fas fa-filter"></i> Filter
                    </button>
                </div>
            </div>
        </form>

        @if (rows != null && rows.Any())
        {
            <!-- Table -->
            <div class="card-body p-0">
                <table class="table table-hover table-striped mb-0">
                    <thead class="thead-dark">
                        <tr>
                            @foreach (var col in rows.First().Keys.Where(c => !hiddenCols.Contains(c)))
                            {
                                <th>@col</th>
                            }
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in rows)
                        {
                            <tr>
                                <!-- Hidden IDs -->
                                <td style="display:none;">
                                    <input type="hidden" class="business-id" value="@row["BusinessId"]" />
                                    <input type="hidden" class="submission-id" value="@row["SubmissionId"]" />
                                </td>

                                <!-- Visible Columns -->
                                @foreach (var col in row.Keys.Where(c => !hiddenCols.Contains(c)))
                                {
                                    var value = row[col];
                                    string displayValue = value is JsonElement je
                                    ? je.ValueKind == JsonValueKind.Null ? "" : je.ToString()
                                    : value?.ToString() ?? "";

                                    <td>@displayValue</td>
                                }

                                <!-- Action Icon -->
                                <td class="text-center">
                                    <button type="button" class="btn btn-sm btn-outline-info btn-view" title="View">
                                        <i class="fas fa-eye"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <p class="text-muted text-center">No data found.</p>
        }
    </div>
</div>



@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/manager/lead/formvalues/dynamic-message-index.js"></script>
}


