@using Core.ViewModels.Dto.Auth
@using Core.ViewModels.Dto.Auth.Auth
@model AuthResponseDto

@{
    ViewData["Title"] = "Privacy Policy";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">

            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-header bg-dark text-white rounded-top-4">
                    <h4 class="mb-0"><i class="bi bi-shield-lock-fill me-2"></i>Privacy & Auth Tokens</h4>
                </div>

                <div class="card-body bg-light-subtle p-4">
                    <p class="lead">This page displays sensitive tokens after authentication.</p>

                    <ul class="list-group list-group-flush rounded-3">
                        <li class="list-group-item">
                            <strong>♻️ Refresh Token:</strong><br />
                            <code class="text-break">@Model?.RefreshToken</code>
                        </li>

                        <li class="list-group-item">
                            <strong>🔑 Access Token:</strong><br />
                            <code class="text-break">@Model?.Token</code>
                        </li>
                    </ul>
                </div>

                <div class="card-footer text-muted text-end">
                    <small>&copy; @DateTime.Now.Year | Auth Viewer</small>
                </div>
            </div>

        </div>
    </div>
</div>

