@model Core.Models.Common.RequestLogs

@{
    ViewData["Title"] = "Request Log Details";
}

<div class="card shadow-lg border-0 rounded-3">
    <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
        <h4 class="mb-0">Request/Response Log #@Model.Id</h4>
        <span class="badge bg-primary">@Model.Method</span>
    </div>

    <div class="card-body">
        <dl class="row">

            <dt class="col-sm-3">Path</dt>
            <dd class="col-sm-9">
                <code>@Model.Path</code>
            </dd>

            <dt class="col-sm-3">User</dt>
            <dd class="col-sm-9">@Model.UserId</dd>

            <dt class="col-sm-3">Status Code</dt>
            <dd class="col-sm-9">
                <span class="badge @(Model.StatusCode >= 200 && Model.StatusCode < 300 ? "bg-success" : "bg-danger")">
                    @Model.StatusCode
                </span>
            </dd>

            <dt class="col-sm-3">Created</dt>
            <dd class="col-sm-9">@Model.CreatedDate.ToString("yyyy-MM-dd HH:mm:ss")</dd>

            <dt class="col-sm-3">Request</dt>
            <dd class="col-sm-9">
                @if (!string.IsNullOrEmpty(Model.Request))
                {
                    <pre class="bg-light p-3 rounded small" style="white-space: pre-wrap; word-wrap: break-word;">
                            @Model.Request
                        </pre>
                }
                else
                {
                    <span class="text-muted">No request body/query params</span>
                }
            </dd>

            <dt class="col-sm-3">Response</dt>
            <dd class="col-sm-9">
                @if (!string.IsNullOrEmpty(Model.Response))
                {
                    <pre class="bg-dark text-warning p-3 rounded small" style="white-space: pre-wrap; word-wrap: break-word;">
                            @Model.Response
                        </pre>
                }
                else
                {
                    <span class="text-muted">No response body</span>
                }
            </dd>
        </dl>
    </div>
</div>
